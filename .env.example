APP_NAME=Ynix FastAPI Core
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_VERSION=1.0.0

# Database
# Principal: mysql
# Opcionais: sqlite, pgsql
DB_CONNECTION=mysql
DB_DRIVER=pymysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ynix_core
DB_USERNAME=root
DB_PASSWORD=
CREATE_TABLES_ON_STARTUP=true

# Para SQLite local rapido:
# DB_CONNECTION=sqlite
# DB_DATABASE=database.sqlite

# Para PostgreSQL opcional:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=ynix_core
# DB_USERNAME=postgres
# DB_PASSWORD=

JWT_SECRET=change-this-secret
JWT_EXPIRES_MINUTES=1440

API_KEY_PREFIX=ynix
ADMIN_SECRET=
MAINTENANCE_STATE_PATH=storage/maintenance.json
CORS_ORIGINS=*
MAX_REQUEST_SIZE_BYTES=2097152

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

REQUEST_LOG_ENABLED=true
REQUEST_LOG_SAVE_BODY=false
ERROR_LOG_ENABLED=true
SECURITY_LOG_ENABLED=true
IP_BLOCK_ENABLED=true
ADMIN_AUDIT_ENABLED=true
SYSTEM_HEALTH_ENABLED=true

ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

SUPERVISOR_ENABLED=true
SUPERVISOR_RESTART_ON_CRASH=true
SUPERVISOR_MAX_RESTARTS=10
SUPERVISOR_RESTART_DELAY_SECONDS=3

QUEUE_CONNECTION=sync
QUEUE_NAME=default
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY_SECONDS=5
REDIS_URL=redis://127.0.0.1:6379/0

SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60

LOG_LEVEL=INFO
